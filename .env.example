# ── Database ────────────────────────────────────────────────────────────────
DB_SERVER=myserver.database.windows.net
DB_DATABASE=mydatabase
# Comma-separated schemas to reflect. `dbo,ppm` matches the example database/seed.sql.
DB_SCHEMAS=dbo,ppm
# (No DB_DRIVER: the mssql-python driver is bundled with the app — nothing to
# install or name. Integration tests still use pyodbc + ODBC Driver 17/18 to
# bootstrap their Docker SQL Server.)

# ── Database-managed columns (optional) ─────────────────────────────────────
# Columns the database populates itself via DEFAULT/trigger (audit columns are
# the canonical case). Excluded from every write payload so the database owns
# the value. Case-insensitive, comma-separated. Set to empty if you have none.
#
# Trigger-populated columns can't be detected structurally — SQL Server exposes
# no link between a trigger and the columns it writes — so they must be named
# here. The values below match the database/seed.sql example, whose AFTER
# INSERT, UPDATE triggers stamp these via SUSER_SNAME() / SYSUTCDATETIME().
DB_AUDIT_COLUMNS=CreatedBy,CreatedDate,ModifiedBy,ModifiedDate

# ── Bulk operations (optional) ──────────────────────────────────────────────
# Max rows a single bulk operation (e.g. bulk delete) may touch. The whole
# batch runs in one transaction (all-or-nothing); this caps that transaction's
# size. Requests over the cap are refused rather than truncated. Defaults to 1000.
# BULK_MAX_ROWS=1000

# ── Dev ─────────────────────────────────────────────────────────────────────
# `DEBUG`, `INFO`, or `WARNING` — defaults to `INFO`
LOG_LEVEL=DEBUG

# ── Observability (optional) ─────────────────────────────────────────────────
# How the signed-in user appears in logs: `email` (default), `hash` (a stable
# pseudonym — correlatable, no PII), or `none`. See app/config.py.
# LOG_USER_IDENTITY=email
# Salt for `hash` mode, to resist reversing known addresses.
# LOG_USER_IDENTITY_SALT=
# Application Insights, injected by the App Service in Azure (telemetry is a
# no-op without it). Set locally only to test export.
# APPLICATIONINSIGHTS_CONNECTION_STRING=
# Fraction of request traces to keep, 0.0–1.0 (default 1.0). Lower to cap
# ingestion cost on a chatty deployment.
# APPINSIGHTS_SAMPLING_RATIO=1.0

# ── Dev auth proxy (dev_auth_proxy.py only) ──────────────────────────────────
# The proxy reuses your `az login` session — nothing to set here for auth.
# Optional: ports the proxy forwards to / listens on (defaults shown).
# APP_PORT=8000
# PROXY_PORT=8001
